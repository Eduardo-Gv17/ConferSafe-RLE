# Copia este archivo a .env y completa los valores

# ── Gemini ─────────────────────────────────────────────────────────────────────
# Obtén tu API key gratis en https://aistudio.google.com/
#GEMINI_API_KEY=

# ── Base de datos ──────────────────────────────────────────────────────────────
# SQLite (por defecto, no requiere configuración extra):
# DATABASE_URL=sqlite:///./confersafe.db

# PostgreSQL (descomenta cuando migres):
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/confersafe
